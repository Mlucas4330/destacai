{
  "manifest_version": 3,
  "name": "AbordaAI",
  "description": "AI-powered LinkedIn outreach for job seekers.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.ngrok-free.app/*"
  ]
}