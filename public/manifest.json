{
  "manifest_version": 3,
  "name": "DestacaAI",
  "version": "0.1.0",
  "description": "Generate custom CVs using AI",
  "permissions": ["storage", "contextMenus", "alarms"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "DestacaAI",
    "default_icon": {
      "128": "icon.png"
    }
  }
}
